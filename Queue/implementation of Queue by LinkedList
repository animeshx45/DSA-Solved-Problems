class Node{
    int val;
    Node next;
    Node(int val){
        this.val = val;
    }
}
class MyQueue{
    Node head ;
    Node tail;
    public void add(int val){
        Node temp = new Node(val);
        if (tail == null) head = tail = temp;
        tail.next = temp;
        tail = temp;
    }
    public void remove(){
        head = head.next;
    }
    public int peek(){
        Node temp = head;
        return temp.val;
    }
    public int size(){
        int size = 0;
        Node temp = head;
        while(temp!=null){
            size++;
            temp = temp.next;
        }
        return size;
    }
    public void print(){
        Node temp = head;
        while(temp!=null){
            System.out.print(temp.val+" ");
            temp = temp.next;
        }
    }
}
public class queueImplementationwithLinkedList {
    static void main() {
        MyQueue mq = new MyQueue();
        mq.add(10);mq.add(20);mq.add(30);mq.add(40);mq.add(50);
        mq.add(98);
        mq.remove();
        mq.print();
        System.out.println(mq.peek());
        System.out.println(mq.size());
    }
}
