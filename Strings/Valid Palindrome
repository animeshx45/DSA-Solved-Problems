class Solution {
    public boolean isPalindrome(String s) {
        s= s.toLowerCase();
        StringBuilder  sb = new StringBuilder();
        char ch [] = s.toCharArray();
        for(int i =0;i<ch.length;i++){
            if(((ch[i]+0)>=97 && (ch[i]+0)<=122 )||((ch[i]+0)>=48 && (ch[i]+0)<=57)){
                sb.append(ch[i]);
            }
        }
        s =sb.toString();
        String ptr = sb.reverse().toString();
        if(s.equals(ptr)) return true;
        else return false;
    }
}
