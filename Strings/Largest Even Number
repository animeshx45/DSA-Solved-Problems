class Solution {
    public String largestEven(String s) {
        StringBuilder sb = new StringBuilder(s);
        int n = sb.length();
        if(sb.charAt(n-1)=='2') return sb.toString();
        for(int i =n-1;i>=0;i--){
            if(sb.charAt(i)=='1'){
                sb.deleteCharAt(i);
            }
            else{
                break;
            }
        }
        String str = sb.toString();
        return str;
    }
}