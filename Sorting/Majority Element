class Solution {
        public int majorityElement(int[] nums) {
        double t  = nums.length;
        double x = Math.floor(t/2);
        int y = (int)x;
        int n = (int)t;
        for(int i =0;i<n;i++){
            int count =0;
            for(int j = 0;j<n;j++){
                if(nums[i]==nums[j]){
                    count++;
                }
            }
            if(count > y) return nums[i];
        }
        return -1;
        
    }
}
