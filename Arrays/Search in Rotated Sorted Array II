import java.util.Arrays;
class Solution {
    public boolean search(int[] nums, int target) {
        Arrays.sort(nums);
        int n = nums.length;
        int lo =0;int hi =n-1;
        while(lo<=hi){
            int mid = (lo+hi)/2;
            if(nums[mid]>target){
                hi = mid-1;
            }
            else if(nums[mid]<target){
                lo = mid+1;
            }
            else{
             return true;
            }
        }
        return false;
    }
}