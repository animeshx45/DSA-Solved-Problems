class Solution {
    public int percentageLetter(String s, char letter) {
        int n = s.length();
        double count = 0;
        for(int i =0;i<n;i++){
            if(s.charAt(i)==letter){
                count++;
            }
        }
        double percentage = (count/n)*100;
        int ans = (int)percentage;
        return ans;
    }
}