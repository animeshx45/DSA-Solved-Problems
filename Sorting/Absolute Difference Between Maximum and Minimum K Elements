import java.util.Arrays;
class Solution {
    public int absDifference(int[] nums, int k) {
        int n = nums.length;
        Arrays.sort(nums);
        int sumofsmall = 0;
        int sumoflarge = 0;
        for(int i=0;i<k;i++){
            sumofsmall = sumofsmall+nums[i];
        }
        for(int i =n-1;i>=n-k;i--){
            sumoflarge = sumoflarge+nums[i];
        }
        int ans = Math.abs(sumoflarge-sumofsmall);
        return ans;
                
    }
}
