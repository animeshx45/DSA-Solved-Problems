/**
 * Definition for a binary tree node.
 * public class TreeNode {
 *     int val;
 *     TreeNode left;
 *     TreeNode right;
 *     TreeNode() {}
 *     TreeNode(int val) { this.val = val; }
 *     TreeNode(int val, TreeNode left, TreeNode right) {
 *         this.val = val;
 *         this.left = left;
 *         this.right = right;
 *     }
 * }
 */
class Solution {
    public static void add(TreeNode root,ArrayList<Integer> list){
        if(root == null){
            return;
        }
        list.add(root.val);
        add(root.left,list);
        add(root.right,list);
    }
    public boolean isUnivalTree(TreeNode root) {
        ArrayList<Integer> list = new ArrayList<Integer>();
        add(root,list);
        int num = list.get(0);
        for(int i = 0; i<list.size();i++){
            if(list.get(i)!=num){
                return false;
            }
        }
        return true;
    }
}
