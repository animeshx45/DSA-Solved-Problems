import java.util.ArrayList;
class Solution {
    public int removeDuplicates(int[] nums) {
        int n = nums.length;
        ArrayList<Integer> list = new ArrayList<Integer>();
        list.add(nums[0]);
        for(int i =1;i<n;i++){
            if(nums[i]!=nums[i-1]){
                list.add(nums[i]);
            }
        }
        int k = list.size();
        for(int i =0;i<k;i++){
            nums[i]=list.get(i);
        }
        return k;
    }
}