import java.util.ArrayList;
class Solution {
    public int removeElement(int[] nums, int val) {
        int n = nums.length;
        ArrayList<Integer> list = new ArrayList<Integer>();
        for(int i =0; i<n;i++){
            if(nums[i]== val){
                continue;
            }
            else{
            list.add(nums[i]);
            }
        }
        for(int i =0;i<list.size();i++){
            nums[i]=list.get(i);
        }
        return list.size();



    }
}