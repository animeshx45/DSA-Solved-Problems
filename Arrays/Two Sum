class Solution {
    public int[] twoSum(int[] nums, int target) {
        int [] arr = new int[2];
        int n = nums.length;
        int index1 =0;
        int index2 =0;
        for(int i =0;i<n;i++){
            for(int j =i+1;j<n;j++){
                if(nums[i]+nums[j]==target){
                    index1 = i;
                    index2 = j;
                }
            }
        }
        arr[0]= index1;
        arr[1]= index2;
        return arr;

    }
}