import java.util.ArrayList;
class Solution {
    public int[] getConcatenation(int[] nums) {
        int n = nums.length;
        int [] ans = new int[2*n];
        ArrayList<Integer> list = new ArrayList<>();
        for(int i =0;i<n;i++){
            list.add(nums[i]);
        }
        for(int i =0;i<n;i++){
            list.add(nums[i]);
        }
        for(int i =0;i<list.size();i++){
            ans[i]=list.get(i);
        }
        return ans;
    }
}